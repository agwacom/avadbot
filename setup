#!/usr/bin/env bash
# avadbot setup — install all skills to ~/.claude/skills/
set -e

AVADBOT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$AVADBOT_DIR/skills"
CLAUDE_SKILLS="$HOME/.claude/skills"
BROWSE_BIN="$SKILLS_DIR/browse/dist/browse"

# 1. Ensure ~/.claude/skills/ exists
mkdir -p "$CLAUDE_SKILLS"

# 2. Build browse binary if needed
if [ -d "$SKILLS_DIR/browse/src" ]; then
  NEEDS_BUILD=0
  if [ ! -x "$BROWSE_BIN" ]; then
    NEEDS_BUILD=1
  elif [ -n "$(find "$SKILLS_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
    NEEDS_BUILD=1
  fi

  if [ "$NEEDS_BUILD" -eq 1 ]; then
    echo "Building browse binary..."
    if ! command -v bun &>/dev/null; then
      echo "Installing bun..."
      curl -fsSL https://bun.sh/install | bash
      export PATH="$HOME/.bun/bin:$PATH"
    fi
    (
      cd "$AVADBOT_DIR"
      bun install
      bun build --compile skills/browse/src/cli.ts --outfile skills/browse/dist/browse
    )
  fi

  # Ensure Playwright Chromium is available
  if [ -x "$BROWSE_BIN" ]; then
    if ! (cd "$AVADBOT_DIR" && bun --eval 'import { chromium } from "playwright"; const b = await chromium.launch(); await b.close();') >/dev/null 2>&1; then
      echo "Installing Playwright Chromium..."
      (cd "$AVADBOT_DIR" && bunx playwright install chromium)
    fi
  fi
fi

# 3. Copy each skill to ~/.claude/skills/
installed=()
for skill_dir in "$SKILLS_DIR"/*/; do
  [ -f "$skill_dir/SKILL.md" ] || continue
  skill_name="$(basename "$skill_dir")"

  target="$CLAUDE_SKILLS/$skill_name"

  # Remove old version, copy fresh
  rm -rf "$target"
  cp -r "$skill_dir" "$target"
  touch "$target/.avadbot-managed"
  # Remove template files — development only, not needed by end users
  find "$target" -name '*.tmpl' -delete
  installed+=("$skill_name")
done

# Guard: ensure at least one skill was found
if [ ${#installed[@]} -eq 0 ]; then
  echo "ERROR: No skills found in $SKILLS_DIR/*/SKILL.md" >&2
  echo "Expected: avad-ship, avad-review, avad-qa, browse, ..." >&2
  exit 1
fi

# One-time migration: remove setup-browser-cookies (merged into browse 1.1.4)
rm -rf "$CLAUDE_SKILLS/setup-browser-cookies"

# One-time migration: remove avad-qa-report (merged into avad-qa 1.1.4)
rm -rf "$CLAUDE_SKILLS/avad-qa-report"

# 4. Prune avadbot skills that no longer exist in source
for installed_dir in "$CLAUDE_SKILLS"/*/; do
  skill_name="$(basename "$installed_dir")"
  [ -f "$installed_dir/.avadbot-managed" ] || continue
  [ -f "$SKILLS_DIR/$skill_name/SKILL.md" ] && continue
  echo "  pruning removed skill: $skill_name"
  rm -rf "$installed_dir"
done

# 5. Ensure ~/.avadbot/ data directory exists
mkdir -p "$HOME/.avadbot/projects"

# 6. Summary
echo ""
echo "avadbot ready."
if [ -x "$BROWSE_BIN" ]; then
  echo "  browse: $BROWSE_BIN"
fi
if [ ${#installed[@]} -gt 0 ]; then
  echo "  installed: ${installed[*]}"
fi
echo ""
echo "Add to ~/.claude/CLAUDE.md:"
echo "  Available skills: /${installed[*]// /, \/}"
